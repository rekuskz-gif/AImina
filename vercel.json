{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/widget.js",
      "dest": "/widget.js"
    },
    {
      "src": "/chat_window.html",
      "dest": "/chat_window.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
